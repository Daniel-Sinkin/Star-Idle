CompileFlags:
  Add:
    - -nostdinc++
    - -isystem
    - /opt/homebrew/opt/gcc/include/c++/15
    - -isystem
    - /opt/homebrew/opt/gcc/include/c++/15/aarch64-apple-darwin25
    - -isystem
    - /opt/homebrew/opt/gcc/include/c++/15/backward
    - -isystem
    - /opt/homebrew/opt/gcc/lib/gcc/current/gcc/aarch64-apple-darwin25/15/include-fixed
